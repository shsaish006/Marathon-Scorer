# ==========================================================================
# AWS Serverless Marathon Scorer - Environment Configuration
# ==========================================================================

# PostgreSQL Connection String (Neon, AWS RDS, or Local Postgres)
# Format: postgres://<username>:<password>@<host>:<port>/<database_name>?sslmode=require
DATABASE_URL=postgres://postgres:marathonpass@localhost:5432/marathon_scorer

# Local Listening Port
PORT=5000

# Application Environment Mode (development or production)
NODE_ENV=development
